  V1["Validate · Step 1<br/>linkml-validate · source schema"]
  BR[("Bronze · source-validated")]
  SLV[("Silver · per-path graph")]
  MR["Integrate · graph merge · entity resolution"]
  V3["Publish · Step 3<br/>linkml-validate · domain schema"]
  GLD[("Gold · domain-conformant")]
  Q1[("Source quarantine")]
  Q3[("Domain quarantine")]

  S1 --> A1 --> V1
  S2 & S3 & S4 --> A2 --> V1
  S7 --> A2 --> V1
  S5 --> A3 --> V1
  S6 --> A4 --> V1

  V1 -->|pass| BR
  V1 -->|reject| Q1

  SM1 & SM2 & SM5 -.->|schema| V1

  BR --> T1 & T2 & T3 & T4 & T5 & T6 & T7
  T1 & T2 & T3 & T4 & T5 & T6 & T7 -->|Transform · Step 2 · production| SLV
  BR -->|untransformed| SLV

  SLV --> MR --> V3
  V3 -->|pass| GLD
  V3 -->|reject| Q3
  DM -.->|schema| V3

